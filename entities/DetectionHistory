{
  "name": "DetectionHistory",
  "type": "object",
  "properties": {
    "page_url": {
      "type": "string",
      "description": "URL of the page that was scanned"
    },
    "page_title": {
      "type": "string",
      "description": "Title of the scanned page"
    },
    "author_name": {
      "type": "string"
    },
    "detections_count": {
      "type": "number",
      "default": 0
    },
    "highlight_types": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Types of highlights found"
    },
    "scan_date": {
      "type": "string",
      "format": "date"
    }
  },
  "required": [
    "page_url"
  ]
}
